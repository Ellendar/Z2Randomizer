<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <Js65Version>1.0.7</Js65Version>
    <AvaloniaVersion>12.0.2</AvaloniaVersion>
    <DialogHostAvaloniaVersion>0.12.1</DialogHostAvaloniaVersion>
    <MaterialAvaloniaVersion>3.16.0</MaterialAvaloniaVersion>
    <MaterialIconsAvaloniaVersion>3.0.2</MaterialIconsAvaloniaVersion>
    <SkiaSharpVersion>3.119.3-preview.1.1</SkiaSharpVersion> <!-- Match version used by Avalonia internally -->
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
    <SuppressTrimAnalysisWarnings>false</SuppressTrimAnalysisWarnings>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <EnableWorkloadRestore>true</EnableWorkloadRestore>
    <TrimmerSingleWarn>false</TrimmerSingleWarn>

    <TrimMode>partial</TrimMode>
    <WasmEmitSymbolMap>true</WasmEmitSymbolMap>
<!--    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>-->
<!--    <PublishTrimmed>true</PublishTrimmed>-->
  </PropertyGroup>

  <ItemGroup>
    <Workload Include="wasm-tools" />
  </ItemGroup>
</Project>
